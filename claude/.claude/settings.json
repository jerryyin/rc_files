{
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "IS_SANDBOX": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": [
      "Read(~/.ssh/id_*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-opus-4-6",
  "skipDangerousModePermissionPrompt": true
}
