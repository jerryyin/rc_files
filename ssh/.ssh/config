# Default GitHub SSH identity: personal account.
# StrictHostKeyChecking accept-new: this redirects to ssh.github.com:443 (for
# networks that block outbound port 22), so a fresh machine's known_hosts
# never has [ssh.github.com]:443 pre-seeded and a plain `git clone
# git@github.com:...` would otherwise fail with "Host key verification
# failed" on first use. accept-new auto-trusts only genuinely new hosts; it
# still refuses (and warns loudly) if an existing entry's key ever changes.
Host github.com
  AddKeysToAgent yes
  HostName ssh.github.com
  Port 443
  User git
  IdentityFile ~/.ssh/id_rsa
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
  StrictHostKeyChecking accept-new

# Enterprise GitHub SSH identity.
# Use remotes like: git@github-e:AMD-Triton/triton-mi450.git
Host github-e
  AddKeysToAgent yes
  HostName ssh.github.com
  Port 443
  User git
  IdentityFile ~/.ssh/id_enterprise
  IdentitiesOnly yes
  StrictHostKeyChecking accept-new

